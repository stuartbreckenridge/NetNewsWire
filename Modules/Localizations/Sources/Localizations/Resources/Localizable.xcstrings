        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "区域繁忙：服务器太忙，无法处理区域操作。"
          }
        }
      }
    },
    "label.text.zone-not-found-the-specified-record-zone-does-not-exist-on-the-server": {
      "comment": "Known iCloud Error.",
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Zone Not Found: the specified record zone does not exist on the server."
          }
        },
