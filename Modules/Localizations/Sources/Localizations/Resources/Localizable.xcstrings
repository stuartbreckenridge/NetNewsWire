    "label.text.partial-failure-some-items-failed-but-the-operation-succeeded-overall": {
      "comment": "Known iCloud Error.",
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Partial Failure: some items failed, but the operation succeeded overall."
          }
        },
        "de": {
          "stringUnit": {
            "state": "translated",
            "value": "Teilweiser Fehler: Einige Elemente sind fehlgeschlagen, aber der Vorgang war insgesamt erfolgreich."
          }
        },
        "fr": {
          "stringUnit": {
            "state": "translated",
            "value": "Échec partiel : certains éléments ont échoué, mais l'opération a globalement réussi."
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "Fallo Parcial: algunos elementos fallaron, pero la operación fue exitosa en general."
          }
        },
        "it": {
          "stringUnit": {
            "state": "translated",
            "value": "Errore parziale: alcuni elementi non sono riusciti, ma l'operazione è riuscita nel complesso."
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "部分失败：某些项目失败，但操作总体成功。"
          }
        }
      }
    },
    "label.text.participant-may-need-verification-you-are-not-a-member-of-the-share": {
