        },
        "fr": {
          "stringUnit": {
            "state": "translated",
            "value": "Violation de référence : la cible de la référence parent ou de partage d'un enregistrement n'a pas été trouvée."
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "Infracción de referencia: no se encontró el destino de la referencia principal o compartida de un registro."
          }
