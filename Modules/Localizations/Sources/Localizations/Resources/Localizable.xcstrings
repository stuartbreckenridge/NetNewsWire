    "label.text.are-you-sure-you-want-to-remove-this-account-netnewswire-will-no-longer-be-able-to-access-articles-and-feeds-unless-the-account-is-added-again": {
      "comment": "Log Out and Remove Account.",
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Are you sure you want to remove this account? NetNewsWire will no longer be able to access articles and feeds unless the account is added again."
          }
        },
        "de": {
          "stringUnit": {
            "state": "translated",
            "value": "Möchten Sie dieses Konto wirklich entfernen? NetNewsWire kann nicht mehr auf Artikel und Feeds zugreifen, es sei denn, das Konto wird erneut hinzugefügt."
          }
        },
        "fr": {
          "stringUnit": {
            "state": "translated",
            "value": "Etes-vous sûr de vouloir supprimer ce compte ? NetNewsWire ne pourra plus accéder aux articles et aux flux à moins que le compte ne soit à nouveau ajouté."
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "¿Estás seguro de que deseas eliminar esta cuenta? NetNewsWire ya no podrá acceder a artículos y feeds a menos que se agregue nuevamente la cuenta."
          }
        },
        "it": {
          "stringUnit": {
            "state": "translated",
            "value": "Sei sicuro di voler rimuovere questo account? NetNewsWire non sarà più in grado di accedere ad articoli e feed a meno che l'account non venga aggiunto nuovamente."
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "您确定要删除此帐户吗？ NetNewsWire 将无法再访问文章和提要，除非再次添加该帐户。"
          }
        }
      }
    },
