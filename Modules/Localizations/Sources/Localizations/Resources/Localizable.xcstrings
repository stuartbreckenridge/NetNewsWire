    "label.text.constraint-violation-the-server-rejected-the-request-because-of-a-conflict-with-a-unique-field": {
      "comment": "Known iCloud Error.",
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Constraint Violation: the server rejected the request because of a conflict with a unique field."
          }
        },
        "de": {
          "stringUnit": {
            "state": "translated",
            "value": "Einschränkungsverletzung: Der Server hat die Anfrage aufgrund eines Konflikts mit einem eindeutigen Feld abgelehnt."
          }
        },
        "fr": {
          "stringUnit": {
            "state": "translated",
            "value": "Violation de contrainte : le serveur a rejeté la demande en raison d'un conflit avec un champ unique."
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "Violación de restricción: el servidor rechazó la solicitud debido a un conflicto con un campo único."
          }
        },
        "it": {
          "stringUnit": {
            "state": "translated",
            "value": "Violazione vincolo: il server ha rifiutato la richiesta a causa di un conflitto con un campo univoco."
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "违反约束：由于与唯一字段冲突，服务器拒绝了请求。"
          }
        }
      }
    },
