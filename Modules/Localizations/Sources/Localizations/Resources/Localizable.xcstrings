        "de": {
          "stringUnit": {
            "state": "translated",
            "value": "NetNewsWire verwendet Ihr iCloud-Konto, um Ihre Abonnements auf Ihren Mac- und iOS-Geräten zu synchronisieren."
          }
        },
        "fr": {
          "stringUnit": {
            "state": "translated",
