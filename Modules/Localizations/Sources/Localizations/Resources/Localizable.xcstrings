        },
        "fr": {
          "stringUnit": {
            "state": "translated",
            "value": "Ajoutez un compte en cliquant sur le bouton +."
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "Agregue una cuenta haciendo clic en el botón +."
          }
        },
        "it": {
          "stringUnit": {
            "state": "translated",
            "value": "Aggiungi un account facendo clic sul pulsante +."
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "单击 + 按钮添加帐户。"
