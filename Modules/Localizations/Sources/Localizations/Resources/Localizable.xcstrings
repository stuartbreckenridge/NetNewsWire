    "label.text.zone-busy-the-server-is-too-busy-to-handle-the-zone-operation": {
      "comment": "Known iCloud Error.",
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Zone Busy: the server is too busy to handle the zone operation."
          }
        },
        "de": {
          "stringUnit": {
            "state": "translated",
            "value": "Zone ausgelastet: Der Server ist zu ausgelastet, um den Zonenbetrieb zu bewältigen."
          }
        },
        "fr": {
          "stringUnit": {
            "state": "translated",
            "value": "Zone occupée : le serveur est trop occupé pour gérer le fonctionnement de la zone."
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "Zona ocupada: el servidor está demasiado ocupado para manejar la operación de la zona."
          }
        },
        "it": {
          "stringUnit": {
            "state": "translated",
            "value": "Zona occupata: il server è troppo occupato per gestire l'operazione di zona."
