    "label.text.netnewswire-will-use-your-icloud-account-to-sync-your-subscriptions-across-your-mac-and-ios-devices": {
      "comment": "Text shown in the app interface: \"NetNewsWire will use your iCloud account to sync your subscriptions across your Mac and iOS devices.\".",
