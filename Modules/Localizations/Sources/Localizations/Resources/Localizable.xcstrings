    "label.text.we-were-unable-to-process-the-selected-file-please-ensure-that-it-is-a-properly-formatted-opml-file": {
      "comment": "Import Failed Message.",
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "We were unable to process the selected file.  Please ensure that it is a properly formatted OPML file."
          }
        },
        "de": {
          "stringUnit": {
            "state": "translated",
            "value": "Die ausgewählte Datei konnte nicht verarbeitet werden.  Bitte stellen Sie sicher, dass es sich um eine ordnungsgemäß formatierte OPML-Datei handelt."
          }
        },
        "fr": {
          "stringUnit": {
            "state": "translated",
            "value": "Nous n'avons pas pu traiter le fichier sélectionné.  Veuillez vous assurer qu'il s'agit d'un fichier OPML correctement formaté."
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "No pudimos procesar el archivo seleccionado.  Asegúrese de que sea un archivo OPML con el formato adecuado."
          }
        },
        "it": {
          "stringUnit": {
            "state": "translated",
            "value": "Non è stato possibile elaborare il file selezionato.  Assicurati che sia un file OPML formattato correttamente."
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "我们无法处理所选文件。  请确保它是格式正确的 OPML 文件。"
          }
        }
      }
    },
