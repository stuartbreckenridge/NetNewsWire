    "label.text.the-icloud-data-was-deleted-please-remove-the-application-icloud-account-and-add-it-again-to-continue-using-the-application-s-icloud-support": {
      "comment": "User deleted zone.",
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "The iCloud data was deleted.  Please remove the application iCloud account and add it again to continue using the application's iCloud support."
          }
        },
        "de": {
          "stringUnit": {
            "state": "translated",
            "value": "Die iCloud-Daten wurden gelöscht.  Bitte entfernen Sie das iCloud-Konto der Anwendung und fügen Sie es erneut hinzu, um die iCloud-Unterstützung der Anwendung weiterhin nutzen zu können."
          }
        },
        "fr": {
          "stringUnit": {
            "state": "translated",
            "value": "Les données iCloud ont été supprimées.  Veuillez supprimer le compte iCloud de l'application et l'ajouter à nouveau pour continuer à utiliser le support iCloud de l'application."
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "Los datos de iCloud fueron eliminados.  Elimine la cuenta de iCloud de la aplicación y agréguela nuevamente para continuar usando el soporte de iCloud de la aplicación."
          }
        },
        "it": {
          "stringUnit": {
            "state": "translated",
            "value": "I dati di iCloud sono stati eliminati.  Rimuovi l'account iCloud dell'applicazione e aggiungilo di nuovo per continuare a utilizzare il supporto iCloud dell'applicazione."
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "iCloud 数据已删除。  请删除该应用程序的 iCloud 帐户并重新添加，以继续使用该应用程序的 iCloud 支持。"
          }
        }
      }
    },
