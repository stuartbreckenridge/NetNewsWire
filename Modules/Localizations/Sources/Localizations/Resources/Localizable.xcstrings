    "label.text.add-an-account-by-clicking-the-button": {
      "comment": "Add Account Explainer.",
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Add an account by clicking the + button."
          }
        },
        "de": {
          "stringUnit": {
            "state": "translated",
            "value": "Fügen Sie ein Konto hinzu, indem Sie auf die Schaltfläche + klicken."
