    "label.text.already-shared-a-record-or-share-cannot-be-saved-because-doing-so-would-cause-the-same-hierarchy-of-records-to-exist-in-multiple-shares": {
      "comment": "Known iCloud Error.",
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Already Shared: a record or share cannot be saved because doing so would cause the same hierarchy of records to exist in multiple shares."
          }
        },
        "de": {
          "stringUnit": {
            "state": "translated",
            "value": "Bereits freigegeben: Ein Datensatz oder eine Freigabe kann nicht gespeichert werden, da dies dazu führen würde, dass dieselbe Datensatzhierarchie in mehreren Freigaben vorhanden wäre."
          }
        },
        "fr": {
          "stringUnit": {
            "state": "translated",
            "value": "Déjà partagé : un enregistrement ou un partage ne peut pas être enregistré, car cela entraînerait l'existence de la même hiérarchie d'enregistrements dans plusieurs partages."
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "Ya compartido: un registro o recurso compartido no se puede guardar porque hacerlo causaría que existiera la misma jerarquía de registros en varios recursos compartidos."
          }
        },
        "it": {
          "stringUnit": {
            "state": "translated",
            "value": "Già condiviso: un record o una condivisione non può essere salvato perché così facendo esisterebbe la stessa gerarchia di record in più condivisioni."
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "已共享：无法保存记录或共享，因为这样做会导致相同的记录层次结构存在于多个共享中。"
          }
        }
      }
    },
