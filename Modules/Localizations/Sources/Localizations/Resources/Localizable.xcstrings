    "label.text.server-record-changed-the-record-was-rejected-because-the-version-on-the-server-is-different": {
      "comment": "Known iCloud Error.",
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Server Record Changed: the record was rejected because the version on the server is different."
