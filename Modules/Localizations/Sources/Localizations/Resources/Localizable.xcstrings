    "label.text.not-authenticated-to-use-the-icloud-account-you-must-enable-icloud-drive-go-to-device-settings-sign-in-to-icloud-then-in-the-app-settings-be-sure-the-icloud-drive-feature-is-enabled": {
      "comment": "Known iCloud Error.",
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Not Authenticated: to use the iCloud account, you must enable iCloud Drive. Go to device Settings, sign in to iCloud, then in the app settings, be sure the iCloud Drive feature is enabled."
          }
        },
        "de": {
          "stringUnit": {
            "state": "translated",
            "value": "Nicht authentifiziert: Um das iCloud-Konto verwenden zu können, müssen Sie iCloud Drive aktivieren. Gehen Sie zu den Geräteeinstellungen, melden Sie sich bei iCloud an und stellen Sie dann in den App-Einstellungen sicher, dass die iCloud Drive-Funktion aktiviert ist."
          }
        },
        "fr": {
          "stringUnit": {
            "state": "translated",
            "value": "Non authentifié : pour utiliser le compte iCloud, vous devez activer iCloud Drive. Accédez aux paramètres de l'appareil, connectez-vous à iCloud, puis dans les paramètres de l'application, assurez-vous que la fonctionnalité iCloud Drive est activée."
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "No autenticado: para utilizar la cuenta de iCloud, debes habilitar iCloud Drive. Vaya a Configuración del dispositivo, inicie sesión en iCloud y luego, en la configuración de la aplicación, asegúrese de que la función iCloud Drive esté habilitada."
          }
        },
        "it": {
          "stringUnit": {
            "state": "translated",
            "value": "Non autenticato: per utilizzare l'account iCloud è necessario abilitare iCloud Drive. Vai alle Impostazioni del dispositivo, accedi a iCloud, quindi nelle impostazioni dell'app, assicurati che la funzione iCloud Drive sia abilitata."
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "未验证：要使用 iCloud 帐户，您必须启用 iCloud Drive。前往设备设置，登录 iCloud，然后在应用程序设置中确保 iCloud Drive 功能已启用。"
          }
        }
      }
    },
