    "label.text.moving-an-open-application-can-cause-unexpected-behavior-relaunch-the-application-to-continue": {
      "comment": "Informative text for app moved while running alert.",
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Moving an open application can cause unexpected behavior. Relaunch the application to continue."
          }
        },
        "de": {
          "stringUnit": {
            "state": "translated",
            "value": "Das Verschieben einer geöffneten Anwendung kann zu unerwartetem Verhalten führen. Starten Sie die Anwendung neu, um fortzufahren."
          }
        },
        "fr": {
          "stringUnit": {
            "state": "translated",
            "value": "Le déplacement d'une application ouverte peut entraîner un comportement inattendu. Relancez l'application pour continuer."
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "Mover una aplicación abierta puede provocar un comportamiento inesperado. Reinicie la aplicación para continuar."
          }
        },
        "it": {
          "stringUnit": {
            "state": "translated",
            "value": "Lo spostamento di un'applicazione aperta può causare comportamenti imprevisti. Riavviare l'applicazione per continuare."
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "移动打开的应用程序可能会导致意外行为。重新启动应用程序以继续。"
          }
        }
      }
    },
