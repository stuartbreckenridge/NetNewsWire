    "label.text.to-add-an-account-to-netnewswire-click-its-icon-above-or-click-the-button-in-the-lower-left": {
      "comment": "Add Account Explainer.",
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "To add an account to NetNewsWire,\nclick its icon above.\n\nOr click the + button in the lower left."
          }
        },
        "de": {
          "stringUnit": {
            "state": "translated",
            "value": "Um ein Konto zu NetNewsWire hinzuzufügen,\nKlicken Sie oben auf das entsprechende Symbol.\n\nOder klicken Sie unten links auf die Schaltfläche „+“."
          }
        },
        "fr": {
          "stringUnit": {
            "state": "translated",
            "value": "Pour ajouter un compte à NetNewsWire,\ncliquez sur son icône ci-dessus.\n\nOu cliquez sur le bouton + en bas à gauche."
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "Para agregar una cuenta a NetNewsWire,\nhaga clic en su icono de arriba.\n\nO haga clic en el botón + en la parte inferior izquierda."
          }
        },
        "it": {
          "stringUnit": {
            "state": "translated",
            "value": "Per aggiungere un account a NetNewsWire,\nfai clic sulla sua icona in alto.\n\nOppure clicca sul pulsante + in basso a sinistra."
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "要将帐户添加到 NetNewsWire，\n单击上面的图标。\n\n或者点击左下角的+按钮。"
          }
        }
      }
    },
    "label.text.to-enable-notifications-open-notifications-in-system-preferences-then-find-netnewswire-in-the-list": {
      "comment": "Text shown in the app interface: \"To enable notifications, open Notifications in System Preferences, then find NetNewsWire in the list.\".",
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "To enable notifications, open Notifications in System Preferences, then find NetNewsWire in the list."
          }
        },
        "de": {
          "stringUnit": {
            "state": "translated",
            "value": "Um Benachrichtigungen zu aktivieren, öffnen Sie „Benachrichtigungen“ in den Systemeinstellungen und suchen Sie dann in der Liste nach „NetNewsWire“."
          }
        },
        "fr": {
          "stringUnit": {
            "state": "translated",
            "value": "Pour activer les notifications, ouvrez Notifications dans les Préférences Système, puis recherchez NetNewsWire dans la liste."
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "Para habilitar las notificaciones, abra Notificaciones en Preferencias del Sistema y luego busque NetNewsWire en la lista."
