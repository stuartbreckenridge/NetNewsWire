    "label.text.a-web-browser-will-open-the-feedly-login-for-you-to-authorize-access": {
      "comment": "Alert informative text when adding a Feedly account and waiting for authorization from the user.",
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "A web browser will open the Feedly login for you to authorize access."
          }
        },
        "de": {
          "stringUnit": {
            "state": "translated",
            "value": "Ein Webbrowser öffnet den Feedly-Login, damit Sie den Zugriff autorisieren können."
          }
        },
        "fr": {
          "stringUnit": {
            "state": "translated",
            "value": "Un navigateur Web ouvrira la connexion Feedly pour vous permettre d'autoriser l'accès."
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "Un navegador web abrirá el inicio de sesión de Feedly para que autorice el acceso."
          }
        },
        "it": {
          "stringUnit": {
            "state": "translated",
            "value": "Un browser web aprirà il login di Feedly per autorizzare l'accesso."
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "Web 浏览器将打开 Feedly 登录，供您授权访问。"
          }
        }
      }
    },
