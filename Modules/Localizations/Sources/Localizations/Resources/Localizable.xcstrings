    "label.text.asset-file-modified-the-content-of-the-specified-asset-file-was-modified-while-being-saved": {
      "comment": "Known iCloud Error.",
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Asset File Modified: the content of the specified asset file was modified while being saved."
          }
        },
        "de": {
          "stringUnit": {
            "state": "translated",
            "value": "Asset-Datei geändert: Der Inhalt der angegebenen Asset-Datei wurde beim Speichern geändert."
          }
        },
        "fr": {
          "stringUnit": {
            "state": "translated",
            "value": "Fichier d'actif modifié : le contenu du fichier d'actif spécifié a été modifié lors de son enregistrement."
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "Archivo de activo modificado: el contenido del archivo de activo especificado se modificó mientras se guardaba."
          }
        },
        "it": {
          "stringUnit": {
            "state": "translated",
            "value": "File di risorse modificato: il contenuto del file di risorse specificato è stato modificato durante il salvataggio."
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "资源文件已修改：指定资源文件在保存时内容被修改。"
          }
        }
      }
    },
